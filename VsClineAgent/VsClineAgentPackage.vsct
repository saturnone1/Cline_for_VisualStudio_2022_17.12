<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <Extern href="stdidcmd.h" />
  <Extern href="vsshlids.h" />

  <Commands package="guidVsClineAgentPackage">
    <Groups>
      <Group guid="guidVsClineAgentCmdSet" id="grpAIAgentMenu" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_VIEW" />
      </Group>
    </Groups>

    <Buttons>
      <Button guid="guidVsClineAgentCmdSet" id="cmdOpenChatWindow" priority="0x0100" type="Button">
        <Parent guid="guidVsClineAgentCmdSet" id="grpAIAgentMenu" />
        <Strings>
          <ButtonText>AI Agent</ButtonText>
          <CommandName>View.AIAgent</CommandName>
          <ToolTipText>Open AI Agent chat window</ToolTipText>
        </Strings>
      </Button>
    </Buttons>
  </Commands>

  <Symbols>
    <GuidSymbol name="guidVsClineAgentPackage" value="{3F8C2A1D-E7B4-4F9E-A8C5-6D2B1F7E3A04}" />

    <GuidSymbol name="guidVsClineAgentCmdSet" value="{7A4E9F2B-1C8D-4B3E-9F7A-2E6C0D8B5A1F}">
      <IDSymbol name="grpAIAgentMenu" value="0x1020" />
      <IDSymbol name="cmdOpenChatWindow" value="0x0100" />
      <IDSymbol name="cmdClearChatHistory" value="0x0101" />
    </GuidSymbol>
  </Symbols>

</CommandTable>
