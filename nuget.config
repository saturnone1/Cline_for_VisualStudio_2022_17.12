<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- 에어갭용 로컬 피드 (LocalPackages/ 폴더에 모든 패키지 포함) -->
    <add key="LocalPackages" value="./LocalPackages" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="LocalPackages">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
